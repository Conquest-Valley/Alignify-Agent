      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prior_call_note_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "basecamp_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reporting_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "producer_note_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
